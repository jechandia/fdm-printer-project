# Copy to `.env` and fill in. Loaded automatically by `docker compose`.

# Which image tag to run. Use a specific version in production (e.g. v1.2.3)
# instead of `latest` so restarts don't accidentally roll forward.
IMAGE_TAG=latest

# Host port to expose. The container always listens on 4000 internally.
SERVER_PORT=4000

# REQUIRED. Used to sign JWTs — generate a long random string and keep it
# stable, rotating it invalidates every existing session.
# Example: openssl rand -hex 48
JWT_SECRET=
