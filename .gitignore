# Dependencies — installed by yarn from lockfile.
node_modules/
**/node_modules/

# Build output.
**/dist/
**/coverage/
**/test-results/

# Runtime state — must come from a writable volume, not committed.
# All persistent state lives under data/ at the workspace root.
data/
backups/
server/.env

# Personal seed file with printer passwords — only the .example template is tracked.
printers.yaml

# Client local config.
client/.env

# Yarn 4 internals — keep releases and cache compressed; ignore install state.
.yarn/install-state.gz
.yarn/cache/.cleaning
**/.yarn/install-state.gz
**/.yarn/cache/.cleaning

# Editor / OS noise.
.idea/
.vscode/*
!.vscode/settings.json
.DS_Store
*.log

# Claude Code — personal local settings (permission allowlist etc.) stay out
# of the repo; launch.json (preview server config) is shared and tracked.
.claude/settings.local.json
