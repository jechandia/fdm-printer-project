# Copy this file to server/.env and tweak the values you actually care about.
# All settings are optional unless marked REQUIRED.

# Server port (default: 4000)
SERVER_PORT=4000
# Possible values: "development" | "production"
NODE_ENV=production
ENABLE_COLORED_LOGS=false

# ──────────────────────────────────────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────────────────────────────────────
# Whether anonymous browsing is blocked. Leave true unless you're behind a
# trusted reverse proxy that handles auth.
OVERRIDE_LOGIN_REQUIRED=true
# Whether the public /register endpoint accepts new signups. Leave false in
# production; new users get created via the FirstTimeSetup wizard or the admin UI.
OVERRIDE_REGISTRATION_ENABLED=false
# REQUIRED for production. Changing this invalidates every existing session.
# Generate one with: openssl rand -hex 48
OVERRIDE_JWT_SECRET=change-me-with-openssl-rand-hex-48
# JWT lifetime in seconds (min 120, default 3600)
OVERRIDE_JWT_EXPIRES_IN=3600
# Issuer / audience claims. Changing them invalidates existing sessions.
OVERRIDE_JWT_ISSUER=fdm-monster
OVERRIDE_JWT_AUDIENCE=fdm-monster

# ──────────────────────────────────────────────────────────────────────────────
# Storage — paths are relative to the server/ workspace at runtime.
# Default puts everything under <repo>/data/ so it's easy to back up.
# ──────────────────────────────────────────────────────────────────────────────
MEDIA_PATH=../data/media
DATABASE_PATH=../data/database
DATABASE_FILE=fdm-monster.sqlite

# ──────────────────────────────────────────────────────────────────────────────
# Printer adapters
# ──────────────────────────────────────────────────────────────────────────────
# PrusaLink HTTP polling cadence (ms). Lower = fresher state, more load on the
# printer's Buddy board. Default 5000, clamped to [1000, 60000].
PRUSA_LINK_POLL_INTERVAL_MS=5000

# ──────────────────────────────────────────────────────────────────────────────
# Diagnostics
# ──────────────────────────────────────────────────────────────────────────────
DEBUG_SOCKET_STATES=false
# Swagger UI lives at /api-docs/. Disable to lock it down in production.
DISABLE_SWAGGER_OPENAPI=false
# Write swagger.json into the media folder on boot (handy for client SDK regen).
GENERATE_SWAGGER_JSON=false
